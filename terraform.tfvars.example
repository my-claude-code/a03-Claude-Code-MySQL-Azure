# Copy this file to terraform.tfvars and fill in the three values below.
# terraform.tfvars is gitignored — it will never be committed.
# Everything else has defaults already set in variables.tf.

subscription_id     = "your-azure-subscription-id"
entra_client_secret = "your-entra-client-secret"
entra_tenant_id     = "your-entra-tenant-id"
